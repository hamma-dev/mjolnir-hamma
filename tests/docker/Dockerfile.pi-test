FROM debian:buster

# Use archive repos since Buster is EOL
RUN sed -i 's|deb.debian.org|archive.debian.org|g' /etc/apt/sources.list && \
    sed -i 's|security.debian.org|archive.debian.org|g' /etc/apt/sources.list && \
    sed -i '/buster-updates/d' /etc/apt/sources.list

# Simulate Pi environment (Buster-based Raspberry Pi OS)
RUN apt-get update && apt-get install -y \
    systemd \
    sudo \
    bash \
    coreutils \
    procps \
    iproute2 \
    wpasupplicant \
    python3 \
    python3-pip \
    python3-venv \
    openssh-client \
    && rm -rf /var/lib/apt/lists/*

# Install pytest for testing
RUN pip3 install pytest

# Create pi user
RUN useradd -m -s /bin/bash pi && \
    echo "pi:raspberry" | chpasswd && \
    usermod -aG sudo pi && \
    echo "pi ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

# Create expected directories
RUN mkdir -p /home/pi/dev && \
    mkdir -p /mnt/usb && \
    chown -R pi:pi /home/pi

# Mock system files
RUN mkdir -p /boot/firmware && touch /boot/firmware/config.txt
RUN mkdir -p /etc/wpa_supplicant /etc/systemd/network /etc/systemd/system

WORKDIR /home/pi/dev/mjolnir-hamma
USER pi

CMD ["/bin/bash"]
